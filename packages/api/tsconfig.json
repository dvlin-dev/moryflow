{
  "extends": "../../tsconfig.agents.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@moryflow/types": ["../types/dist/index.d.ts"],
      "@moryflow/types/*": ["../types/dist/*"],
      "@moryflow/sync": ["../sync/dist/index.d.ts"],
      "@moryflow/sync/*": ["../sync/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
