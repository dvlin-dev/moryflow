// Prisma Schema for Anyhunt - Vector Database
// Memox 向量数据库（MemoryFact、ScopeRegistry）

generator client {
  provider        = "prisma-client"
  output          = "../../generated/prisma-vector"
  outputType      = "commonjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum KnowledgeSourceStatus {
  ACTIVE
  PROCESSING
  FAILED
  DELETED
}

enum SourceRevisionIngestMode {
  INLINE_TEXT
  UPLOAD_BLOB
}

enum KnowledgeSourceRevisionStatus {
  PENDING_UPLOAD
  READY_TO_FINALIZE
  PROCESSING
  INDEXED
  FAILED
  DELETED
}

// =============================================
// Memox - 语义记忆（Mem0 对标）
// =============================================

model MemoryFact {
  id        String   @id @default(uuid())
  apiKeyId  String   // 软引用（无外键约束）

  // 调用方的用户/实体维度
  userId    String?
  agentId   String?
  appId     String?
  runId     String?
  orgId     String?
  projectId String?

  memory    String
  input     Json?    // messages 原始输入
  metadata  Json?
  categories String[] @default([])
  keywords  String[] @default([])
  hash      String?
  immutable Boolean  @default(false)
  graphEnabled Boolean @default(false)
  expirationDate DateTime?
  timestamp DateTime?

  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apiKeyId, userId])
  @@index([apiKeyId, agentId])
  @@index([apiKeyId, appId])
  @@index([apiKeyId, runId])
  @@index([apiKeyId, orgId])
  @@index([apiKeyId, projectId])
  @@index([apiKeyId, createdAt])
}

// =============================================
// Memox - Memory History
// =============================================

model MemoryFactHistory {
  id        String   @id @default(uuid())
  apiKeyId  String
  memoryId  String
  userId    String
  input     Json?
  oldMemory String?
  newMemory String
  event     String
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apiKeyId, memoryId])
  @@index([apiKeyId, userId])
  @@index([apiKeyId, createdAt])
}

// =============================================
// Memox - Memory Feedback
// =============================================

model MemoryFactFeedback {
  id             String   @id @default(uuid())
  apiKeyId       String
  memoryId       String
  feedback       String?
  feedbackReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([apiKeyId, memoryId])
  @@index([apiKeyId, createdAt])
}

// =============================================
// Memox - Memory Export
// =============================================

model MemoryFactExport {
  id        String   @id @default(uuid())
  apiKeyId  String
  filters   Json?
  orgId     String?
  projectId String?
  status    String
  r2Key     String?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([apiKeyId, createdAt])
}

// =============================================
// Memox - Knowledge Sources
// =============================================

model KnowledgeSource {
  id                String                @id @default(uuid())
  apiKeyId          String
  sourceType        String
  externalId        String?
  userId            String?
  agentId           String?
  appId             String?
  runId             String?
  orgId             String?
  projectId         String?
  title             String
  displayPath       String?
  mimeType          String?
  metadata          Json?
  currentRevisionId String?
  status            KnowledgeSourceStatus @default(ACTIVE)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  currentRevision KnowledgeSourceRevision?   @relation("CurrentSourceRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  revisions       KnowledgeSourceRevision[]
  chunks          SourceChunk[]

  @@unique([apiKeyId, sourceType, externalId])
  @@index([apiKeyId, sourceType])
  @@index([apiKeyId, userId])
  @@index([apiKeyId, agentId])
  @@index([apiKeyId, appId])
  @@index([apiKeyId, runId])
  @@index([apiKeyId, orgId])
  @@index([apiKeyId, projectId])
  @@index([apiKeyId, status, createdAt])
}

model KnowledgeSourceRevision {
  id                  String                        @id @default(uuid())
  sourceId            String
  apiKeyId            String
  ingestMode          SourceRevisionIngestMode
  checksum            String?
  userId              String?
  agentId             String?
  appId               String?
  runId               String?
  orgId               String?
  projectId           String?
  contentBytes        Int?
  contentTokens       Int?
  normalizedTextR2Key String?
  blobR2Key           String?
  pendingUploadExpiresAt DateTime?
  mimeType            String?
  status              KnowledgeSourceRevisionStatus
  error               String?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  indexedAt           DateTime?

  source           KnowledgeSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  currentForSource KnowledgeSource[] @relation("CurrentSourceRevision")
  chunks           SourceChunk[]

  @@index([apiKeyId, sourceId, createdAt])
  @@index([apiKeyId, status, createdAt])
  @@index([apiKeyId, checksum])
  @@index([apiKeyId, userId])
  @@index([apiKeyId, agentId])
  @@index([apiKeyId, appId])
  @@index([apiKeyId, runId])
  @@index([apiKeyId, orgId])
  @@index([apiKeyId, projectId])
  @@index([status, pendingUploadExpiresAt])
}

model SourceChunk {
  id         String   @id @default(uuid())
  apiKeyId   String
  sourceId   String
  revisionId String
  userId     String?
  agentId    String?
  appId      String?
  runId      String?
  orgId      String?
  projectId  String?
  chunkIndex Int
  chunkCount Int
  headingPath String[] @default([])
  content    String
  tokenCount Int
  metadata   Json?
  keywords   String[] @default([])
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  source   KnowledgeSource         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  revision KnowledgeSourceRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@unique([revisionId, chunkIndex])
  @@index([apiKeyId, sourceId])
  @@index([apiKeyId, revisionId])
  @@index([apiKeyId, userId])
  @@index([apiKeyId, agentId])
  @@index([apiKeyId, appId])
  @@index([apiKeyId, runId])
  @@index([apiKeyId, orgId])
  @@index([apiKeyId, projectId])
  @@index([apiKeyId, createdAt])
}

// =============================================
// Memox - Scope Registry（user / agent / app / run）
// =============================================

model ScopeRegistry {
  id        String   @id @default(uuid())
  apiKeyId  String
  type      String   // user | agent | app | run
  entityId  String
  name      String?
  metadata  Json?
  orgId     String?
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([apiKeyId, type, entityId])
  @@index([apiKeyId, type])
  @@index([apiKeyId, createdAt])
}

// =============================================
// Memox - Graph Projection
// =============================================

model GraphEntity {
  id            String   @id @default(uuid())
  apiKeyId      String
  entityType    String
  canonicalName String
  aliases       String[] @default([])
  metadata      Json?
  lastSeenAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  outgoingRelations GraphRelation[] @relation("GraphRelationFrom")
  incomingRelations GraphRelation[] @relation("GraphRelationTo")
  observations      GraphObservation[]

  @@unique([apiKeyId, entityType, canonicalName])
  @@index([apiKeyId, entityType])
  @@index([apiKeyId, lastSeenAt])
}

model GraphRelation {
  id           String   @id @default(uuid())
  apiKeyId     String
  fromEntityId String
  toEntityId   String
  relationType String
  confidence   Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fromEntity   GraphEntity         @relation("GraphRelationFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity     GraphEntity         @relation("GraphRelationTo", fields: [toEntityId], references: [id], onDelete: Cascade)
  observations GraphObservation[]

  @@unique([apiKeyId, fromEntityId, toEntityId, relationType])
  @@index([apiKeyId, relationType])
}

model GraphObservation {
  id                String   @id @default(uuid())
  apiKeyId          String
  graphEntityId     String?
  graphRelationId   String?
  evidenceSourceId  String?
  evidenceRevisionId String?
  evidenceChunkId   String?
  evidenceMemoryId  String?
  observationType   String
  payload           Json
  confidence        Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  graphEntity   GraphEntity?   @relation(fields: [graphEntityId], references: [id], onDelete: Cascade)
  graphRelation GraphRelation? @relation(fields: [graphRelationId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, graphEntityId])
  @@index([apiKeyId, graphRelationId])
  @@index([apiKeyId, evidenceSourceId])
  @@index([apiKeyId, evidenceRevisionId])
  @@index([apiKeyId, evidenceChunkId])
  @@index([apiKeyId, evidenceMemoryId])
  @@index([apiKeyId, observationType])
}
