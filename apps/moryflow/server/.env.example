# 数据库
DATABASE_URL="postgresql://dev:dev@localhost:5432/moryflow?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# 环境
NODE_ENV="development"

# 服务端口
PORT="3000"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-change-in-production-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
SYNC_ACTION_SECRET="your-sync-action-secret-min-32-chars"
ADMIN_EMAILS="dvlindev@qq.com"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
AUTH_SOCIAL_EXCHANGE_TTL_SECONDS="120"
MORYFLOW_DEEP_LINK_SCHEME="moryflow"

# CORS - 允许的前端来源（生产环境必须配置）
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,moryflow://"

# Better Auth 信任的来源（用于 CSRF 保护）
TRUSTED_ORIGINS="http://localhost:3000,http://localhost:5173,moryflow://"

# Creem 支付
CREEM_API_KEY="your-creem-api-key"
CREEM_WEBHOOK_SECRET="your-creem-webhook-secret"
CREEM_TEST_MODE="true"

# AI Providers (optional - 配置在数据库 AiProvider 表中)
# 以下仅作为参考，实际 API Key 通过管理后台配置
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_AI_API_KEY=""

# 服务器公网 URL（用于生成预签名 URL）
SERVER_URL="http://localhost:3000"

# Cloudflare R2 存储（云同步）
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="moryflow-storage"
STORAGE_API_SECRET="your-storage-api-secret"
# 云同步 receipt token 签名密钥（必填，不能回退到 STORAGE_API_SECRET）
SYNC_ACTION_SECRET="your-sync-action-secret-min-32-chars"

# Memox（Phase 2 主链路；origin only，不要带 /api/v1）
MEMOX_API_BASE_URL="https://server.anyhunt.app"
MEMOX_API_KEY="ah_your_memox_service_key"
MEMOX_REQUEST_TIMEOUT_MS="15000"

# Legacy vector baseline（Phase 2 rollback window 必填；origin only）
VECTORIZE_API_URL="https://moryflow-vectorize.your-account.workers.dev"

# Memox 搜索后端（Phase 2 默认 memox；仅 rollback rehearsal / rollback window 才切 legacy_vector_baseline）
MORYFLOW_SEARCH_BACKEND="memox"

# Memox 二期本地 rehearsal（可选；默认值已与脚本一致）
MORYFLOW_BASE_URL="http://127.0.0.1:3200/api/v1"
ANYHUNT_BASE_URL="http://127.0.0.1:3100/api/v1"
MEMOX_PHASE2_USER_EMAIL="free.user@example.com"

# Groq API（语音转录）
# 获取地址：https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# Resend 邮件服务（邮箱验证码）
# 获取地址：https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxx"
EMAIL_FROM="Moryflow <noreply@yourdomain.com>"


OPENAI_BASE_URL=
OPENAI_API_KEY=
